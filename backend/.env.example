# Arni Backend Configuration
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# ─── Application ──────────────────────────────────────────────
APP_NAME=Arni
APP_VERSION=0.1.0
DEBUG=True

# ─── MongoDB ──────────────────────────────────────────────────
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=arni

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Frontend URL (for generating invite links) ──────────────
FRONTEND_URL=http://localhost:5173

# ─── Backend URL (used for internal service-to-service calls) ─
# Change this when deploying behind a tunnel or reverse proxy
BACKEND_URL=http://localhost:8000

# ─── JWT ──────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random secret in production!
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ─── Google OAuth (optional) ─────────────────────────────────
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Daily.co (required for video meetings) ──────────────────
# Get API key from: https://dashboard.daily.co/developers
# Free tier: up to 1000 participant minutes/month
DAILY_API_KEY=
DAILY_API_URL=https://api.daily.co/v1

# ─── Deepgram (required for real-time transcription) ─────────
# Get API key from: https://console.deepgram.com
# Free tier: $200 credit
DEEPGRAM_API_KEY=

# ─── DeepSeek (required for AI responses) ────────────────────
# Get API key from: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ─── ElevenLabs (required for text-to-speech) ────────────────
# Get API key from: https://elevenlabs.io
# Free tier: 10k characters/month
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_flash_v2_5

# ─── OpenAI (required for embeddings / RAG) ──────────────────
# Get API key from: https://platform.openai.com
# Used for text-embedding-3-large only (not chat)
OPENAI_API_KEY=

# ─── Fact-Check Tuning ───────────────────────────────────────
FACT_CHECK_CONFIDENCE_THRESHOLD=0.85
FACT_CHECK_COOLDOWN_SECONDS=30

# ─── Host Grace Period ───────────────────────────────────────
HOST_GRACE_PERIOD_MINUTES=10
