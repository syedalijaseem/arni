# Arni Backend Configuration

# Application
APP_NAME=Arni
APP_VERSION=0.1.0
DEBUG=True

# MongoDB
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=arni

# Redis
REDIS_URL=redis://redis:6379

# CORS
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL (for generating invite links)
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Google OAuth (optional)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Daily.co (required for video meetings)
# Get API key from: https://dashboard.daily.co/developers
# Free tier: up to 1000 participant minutes/month
DAILY_API_KEY=
DAILY_API_URL=https://api.daily.co/v1
