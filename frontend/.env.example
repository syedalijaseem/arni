# Arni Frontend Configuration
# Copy this file to .env.local and update as needed:
#   cp .env.example .env.local

# Backend API URL — the Vite dev server proxies /api requests here
# For local Docker Compose development, use http://localhost:8000
# For Cloudflare Tunnel deployment, use your tunnel URL
VITE_BACKEND_URL=http://localhost:8000
